  "description": "Sevices behind the car,taxi,rental and some more.",
  "main": "bin/www.js",
  "type": "module",
  "sourceType": "module",
  "scripts": {
    "test": "node  bin/www.js",
    "start": "nodemon --experimental-specifier-resolution=node bin/www.js",
    "lint:fix": "eslint --fix ./*.js",
    "prepare": "husky install",
    "apiTest": "mocha 'test/**/*.js' -b --timeout 15000 --exit"
  },
