    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "./node_modules/.bin/eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://git.abserve.tech:8001/node_pro/rebustarv3_server.git"
  },
  "keywords": [
    "Rebustar",
    "V3"
  ],
  "engines": {
    "npm": ">=8.0.0 <12.0.0",
    "node": ">=16.0.0 <21.0.0"
  },
  "author": "Abservetech Node Intruders",
  "license": "ISC",
